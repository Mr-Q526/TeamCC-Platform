{
  "name": "@teamcc/skill-graph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./retrieval": "./src/retrieval/index.ts"
  },
  "packageManager": "bun@1.3.5",
  "scripts": {
    "eval:skills": "bun run ./scripts/skillRetrievalEval.ts --retrieval-features ./data/aggregates/skill-retrieval-features.experiment.json",
    "skills:eval:offline": "bun run ./scripts/skillRetrievalEval.ts --mode offline-retrieval --retrieval-features ./data/aggregates/skill-retrieval-features.experiment.json",
    "skills:eval:offline:canonical": "bun run ./scripts/skillRetrievalEval.ts --mode offline-retrieval --retrieval-features ./data/aggregates/skill-retrieval-features.json",
    "skills:eval:graph-preference": "bun run ./scripts/skillRetrievalEval.ts --mode offline-retrieval --cases-dir ./evals/skills/cases/retrieval/graph-preference/v1 --retrieval-features ./data/aggregates/skill-retrieval-features.experiment.json",
    "skills:eval:graph-preference:canonical": "bun run ./scripts/skillRetrievalEval.ts --mode offline-retrieval --cases-dir ./evals/skills/cases/retrieval/graph-preference/v1 --retrieval-features ./data/aggregates/skill-retrieval-features.json",
    "skills:eval:uplift": "bun run ./scripts/skillRetrievalEval.ts --mode graph-uplift",
    "skills:eval:sandbox": "bun run ./scripts/skillRetrievalEval.ts --mode teamcc-sandbox-blind",
    "skills:eval:replay": "bun run ./scripts/skillRetrievalEval.ts --mode replay-diagnosis",
    "skills:langfuse:sync-dataset": "bun run ./scripts/syncLangfuseSkillEvalDataset.ts",
    "skills:langfuse:sync-graph-preference-dataset": "bun run ./scripts/syncLangfuseSkillEvalDataset.ts --dataset-kind graph-preference",
    "skills:langfuse:run-retrieval-experiment": "bun run ./scripts/runLangfuseRetrievalExperiment.ts",
    "skills:eval:generate-retrieval-cases": "bun run ./scripts/generateRetrievalEvalCases.ts",
    "skills:eval:generate-benchmark-cases": "bun run ./scripts/generateBenchmarkRetrievalCases.ts",
    "skills:eval:generate-graph-preference-cases": "bun run ./scripts/generateGraphPreferenceCases.ts",
    "skills:eval:repair-case-metadata": "bun run ./scripts/repairRetrievalCaseMetadata.ts",
    "skills:eval:audit-benchmark-cases": "bun run ./scripts/auditBenchmarkRetrievalCases.ts",
    "skills:eval:audit-graph-preference-cases": "bun run ./scripts/auditBenchmarkRetrievalCases.ts --cases-dir ./evals/skills/cases/retrieval/graph-preference/v1 --summary-path ./evals/skills/reports/retrieval-graph-preference-v1-audit-summary.json --review-sample-path ./evals/skills/reports/retrieval-graph-preference-v1-review-sample.json --skip-quota",
    "skills:facts:init-db": "bun run ./scripts/initSkillFactsDb.ts",
    "skills:facts:seed-pro-feedback": "bun run ./scripts/seedProSkillFeedback.ts",
    "skills:facts:seed-scene-feedback": "bun run ./scripts/seedProSkillFeedback.ts",
    "skills:facts:aggregate": "bun run ./scripts/buildSkillFactAggregates.ts",
    "skills:facts:build-retrieval-features": "bun run ./scripts/buildSkillRetrievalFeatures.ts",
    "skills:facts:build-retrieval-features:live": "bun run ./scripts/buildSkillRetrievalFeatures.ts --preset live",
    "skills:facts:build-retrieval-features:experiment": "bun run ./scripts/buildSkillRetrievalFeatures.ts --preset experiment",
    "skills:facts:db:init": "bun run ./scripts/initSkillFactsDb.ts",
    "skills:graph:build-update-input": "bun run ./scripts/buildSkillAggregateGraphUpdateInput.ts",
    "skills:graph:apply-aggregates": "bun run ./scripts/applySkillAggregateGraphUpdate.ts",
    "skills:graph:apply-aggregates-from-pg": "bun run ./scripts/applySkillAggregateGraphUpdateFromPg.ts",
    "skills:graph:refresh-from-facts": "bun run ./scripts/refreshSkillGraphFromFacts.ts",
    "skills:graph:refresh:worker": "bun run ./scripts/runSkillGraphRefreshWorker.ts",
    "skills:graph:refresh:reconcile": "bun run ./scripts/reconcileSkillGraphRefreshQueue.ts",
    "skills:graph:inspect-feedback-loop": "bun run ./scripts/inspectSkillFeedbackLoop.ts",
    "skills:graph:inspect": "bun run ./scripts/inspectNeo4jSkillGraph.ts",
    "skills:graph:sync-registry": "bun run ./scripts/syncSkillRegistryToNeo4j.ts",
    "skills:graph:reset-demo-local": "bun run ./scripts/resetDemoLocalSkillGraph.ts",
    "skills:retrieve:demo": "bun run ./scripts/retrieveSkillsDemo.ts",
    "skills:audit-aliases": "bun run ./scripts/auditSkillAliases.ts",
    "skills:refresh-aliases": "bun run ./scripts/skillMetadataAliasRefresh.ts",
    "skills:build-registry": "bun run ./scripts/buildSkillRegistry.ts",
    "skills:build-embeddings": "bun run ./scripts/buildSkillEmbeddings.ts",
    "skills:normalize-registry": "bun run ./scripts/skillMetadataAliasRefresh.ts && bun run ./scripts/buildSkillRegistry.ts",
    "skills:db:up": "docker compose -p teamskill-claudecode -f docker-compose.skill-data.yml up -d",
    "skills:db:down": "docker compose -p teamskill-claudecode -f docker-compose.skill-data.yml down",
    "skills:langfuse:up": "docker compose -p teamskill-claudecode -f docker-compose.skill-data.yml up -d langfuse-postgres langfuse-redis langfuse-clickhouse langfuse-minio langfuse-worker langfuse-web",
    "skills:langfuse:down": "docker compose -p teamskill-claudecode -f docker-compose.skill-data.yml stop langfuse-web langfuse-worker langfuse-minio langfuse-clickhouse langfuse-redis langfuse-postgres",
    "skills:langfuse:logs": "docker compose -p teamskill-claudecode -f docker-compose.skill-data.yml logs -f langfuse-web langfuse-worker",
    "skills:db:import-embeddings": "bun run ./scripts/importSkillEmbeddingsToPg.ts",
    "skills:graph:seed-mock": "bun run ./scripts/seedNeo4jSkillGraphV1.ts",
    "skills:graph:seed-v1": "bun run ./scripts/seedNeo4jSkillGraphV1.ts"
  },
  "dependencies": {
    "@langfuse/client": "^5.1.0",
    "pg": "^8.16.3",
    "redis": "^5.11.0",
    "yaml": "*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12"
  }
}
