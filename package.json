{
  "name": "teamcc-admin",
  "version": "0.1.0",
  "description": "Identity & Permission Management Platform for TeamSkill ClaudeCode",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "db:migrate": "drizzle-kit push:sqlite",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^4.25.0",
    "fastify-cors": "^9.0.1",
    "fastify-jwt": "^7.2.4",
    "bcryptjs": "^2.4.3",
    "sqlite": "^5.1.1",
    "better-sqlite3": "^9.2.2",
    "drizzle-orm": "^0.29.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "@types/node": "^20.10.6",
    "@types/bcryptjs": "^2.4.6",
    "drizzle-kit": "^0.20.14",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
